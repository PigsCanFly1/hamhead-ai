# ============================================================
# HAM-HEAD AI — SECRETS TEMPLATE
# Copy this file to tokens.env and fill in your real values.
# NEVER commit tokens.env to git — it is gitignored.
# ============================================================

# ── DOCKER HUB ──────────────────────────────────────────────
# Generate at: https://hub.docker.com/settings/security
DOCKER_USERNAME=your_dockerhub_username
DOCKER_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HOSTINGER ───────────────────────────────────────────────
# API token: https://hpanel.hostinger.com/api-access
# SSH key passphrase (leave blank if key has no passphrase)
HOSTINGER_API_TOKEN=your_hostinger_api_token_here
HOSTINGER_SSH_HOST=your-server-ip-or-hostname
HOSTINGER_SSH_USER=u123456789
HOSTINGER_SSH_KEY_PATH=~/.ssh/hostinger_id_rsa
HOSTINGER_SSH_PASSPHRASE=

# ── DATABASE (PRODUCTION) ───────────────────────────────────
PROD_DATABASE_URL=postgresql://user:password@host:5432/hamheadai

# ── APP SECRETS ─────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-64-chars
POSTGRES_PASSWORD=replace-with-a-strong-database-password
